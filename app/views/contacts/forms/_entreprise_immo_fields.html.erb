<!-- Champs spécifiques aux entreprises et professionnels -->
<div class="grid md:grid-cols-2 gap-6">
  <div>
    <%= form.label :business_activity, "Activité principale *", class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.select :business_activity,
        options_for_select([
          ['Promotion / Développement', 'promotion'],
          ['Construction / Entrepreneur', 'construction'],
          ['Rénovation spécialisée', 'renovation'],
          ['Gestion de patrimoine', 'gestion'],
          ['Syndic professionnel', 'syndic'],
          ['Négociant / Courtier', 'marchand']
        ], ''),
        { prompt: 'Sélectionnez votre activité' },
        { class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-purple-500", required: true } %>
  </div>

  <div>
    <%= form.label :investment_region, "Région d'investissement *", class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.select :investment_region,
        options_for_select([
          ['Wallonie', 'wallonie'],
          ['Flandre', 'flandre'],
          ['Bruxelles-Capitale', 'bruxelles'],
          ['Multi-régional (Belgique)', 'multi'],
          ['International', 'international']
        ], ''),
        { prompt: 'Sélectionnez la région' },
        { class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-purple-500", required: true } %>
  </div>
</div>

<!-- Spécificités du projet -->
<div class="mt-6">
  <label class="block text-sm font-medium text-gray-700 mb-2">Spécificités techniques du projet</label>
  <%= text_area_tag 'project_specifics', '',
      rows: 3,
      placeholder: "Ex: Construction passive, rénovation énergétique, logements sociaux, certification environnementale...",
      class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-purple-500" %>
</div>
