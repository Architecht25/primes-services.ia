<div class="max-w-4xl mx-auto px-4 py-8">
  <div class="text-center mb-8">
    <h1 class="text-3xl font-bold text-gray-900 mb-4">
      Contactez-nous
    </h1>
    <p class="text-lg text-gray-600 max-w-2xl mx-auto">
      Sélectionnez votre profil pour nous contacter. Notre équipe vous accompagnera dans votre projet et répondra à toutes vos questions.
    </p>
  </div>

  <div class="grid md:grid-cols-2 gap-6">
    <!-- Particuliers -->
    <div class="bg-white rounded-lg shadow-lg p-6 border-2 border-transparent hover:border-primary-500 transition-all duration-300">
      <%= link_to particulier_contacts_path, class: "block" do %>
        <div class="text-center">
          <div class="w-16 h-16 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">Particuliers</h3>
          <p class="text-gray-600 mb-4">
            Propriétaires de maisons, appartements, et résidences privées
          </p>
          <ul class="text-sm text-gray-500 space-y-1">
            <li>• Primes rénovation énergétique</li>
            <li>• Isolation et chauffage</li>
            <li>• Panneaux solaires</li>
            <li>• Rénovation façade</li>
          </ul>
        </div>
      <% end %>
    </div>

    <!-- ACP - Associations de Copropriétaires -->
    <div class="bg-white rounded-lg shadow-lg p-6 border-2 border-transparent hover:border-secondary-500 transition-all duration-300">
      <%= link_to acp_contacts_path, class: "block" do %>
        <div class="text-center">
          <div class="w-16 h-16 bg-secondary-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-secondary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">Copropriétés (ACP)</h3>
          <p class="text-gray-600 mb-4">
            Associations de copropriétaires et syndics professionnels
          </p>
          <ul class="text-sm text-gray-500 space-y-1">
            <li>• Primes façade collective</li>
            <li>• Chauffage commun</li>
            <li>• Rénovation toiture</li>
            <li>• Ascenseurs et parties communes</li>
          </ul>
        </div>
      <% end %>
    </div>

    <!-- Entreprises & Professionnels -->
    <div class="bg-white rounded-lg shadow-lg p-6 border-2 border-transparent hover:border-accent-500 transition-all duration-300">
      <%= link_to entreprise_immo_contacts_path, class: "block" do %>
        <div class="text-center">
          <div class="w-16 h-16 bg-accent-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">Entreprises &amp; Professionnels</h3>
          <p class="text-gray-600 mb-4">
            Promoteurs, constructeurs, indépendants et professionnels du secteur
          </p>
          <ul class="text-sm text-gray-500 space-y-1">
            <li>• Aides aux professionnels</li>
            <li>• Rénovation et construction</li>
            <li>• Construction durable</li>
            <li>• Investissements professionnels</li>
          </ul>
        </div>
      <% end %>
    </div>

  </div>

  <div class="mt-8 text-center">
    <div class="bg-primary-50 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-primary-900 mb-2">
        💬 Accompagnement personnalisé
      </h3>
      <p class="text-primary-700">
        Notre équipe analysera votre demande et vous contactera rapidement pour vous accompagner dans votre projet. Chaque formulaire nous permet de mieux comprendre vos besoins spécifiques.
      </p>
    </div>
  </div>
</div>
