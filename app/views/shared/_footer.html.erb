<!-- Footer pour primes-services.ia -->
<footer class="bg-primary-900 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid md:grid-cols-4 gap-8">

      <!-- Logo et description -->
      <div class="md:col-span-2">
        <div class="flex items-center space-x-3 mb-4">
          <div class="w-10 h-10 bg-gradient-to-br from-primary-600 to-secondary-500 rounded-lg flex items-center justify-center">
            <span class="text-white font-bold text-sm">PS</span>
          </div>
          <div>
            <h3 class="text-xl font-bold">Primes Services</h3>
            <p class="text-primary-200 text-sm">Assistant IA spécialisé</p>
          </div>
        </div>

        <p class="text-primary-100 mb-6 max-w-md">
          Experts en subsides belges depuis 15 ans. Notre IA révolutionne l'accompagnement
          pour vos primes et subsides en Flandre, à Bruxelles et en Wallonie.
        </p>

        <div class="flex space-x-4">
          <div class="text-center">
            <div class="text-2xl font-bold text-amber-400">+100M€</div>
            <div class="text-xs text-primary-200">Primes obtenues</div>
          </div>
          <div class="text-center">
            <div class="text-2xl font-bold text-accent-400">+15.000</div>
            <div class="text-xs text-primary-200">Dossiers accompagnés</div>
          </div>
          <div class="text-center">
            <div class="text-2xl font-bold text-secondary-400">+15 ans</div>
            <div class="text-xs text-primary-200">D'expertise</div>
          </div>
        </div>
      </div>

      <!-- Navigation rapide -->
      <div>
