            <% end %>
          </li>
          <li>
            <%= link_to simulation_path, class: "text-primary-100 hover:text-amber-300 transition-colors" do %>
              📚 Simulations
            <% end %>
          </li>
          <li>
            <%= link_to ai_chat_path, class: "text-primary-100 hover:text-amber-300 transition-colors" do %>
              🤖 Chat IA
            <% end %>
          </li>
          <li>
            <a href="https://ren0vate-630b5136c442.herokuapp.com" target="_blank" class="text-primary-100 hover:text-amber-300 transition-colors">
              🔗 Ren0vate
            </a>
          </li>
          <li>
            <%= link_to about_path, class: "text-primary-100 hover:text-amber-300 transition-colors" do %>
              👥 À propos
            <% end %>
          </li>
        </ul>
      </div>

      <!-- Contact et régions -->
      <div>
        <h4 class="text-lg font-semibold mb-4">Contact</h4>
        <ul class="space-y-2 text-primary-100">
          <li>
            <a href="mailto:robin@architecht.be" class="hover:text-amber-300 transition-colors">
