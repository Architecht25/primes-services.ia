<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Administration — Primes Services</title>
    <%= csrf_meta_tags %>
    <%= stylesheet_link_tag "application" %>
  </head>
  <body class="min-h-screen bg-gray-100 flex items-center justify-center">
    <div class="w-full max-w-sm">
      <div class="bg-white rounded-lg shadow-lg p-8">
        <div class="text-center mb-8">
          <h1 class="text-2xl font-bold text-gray-900">Administration</h1>
          <p class="text-gray-500 text-sm mt-1">Primes Services</p>
        </div>

        <% if alert %>
          <div class="bg-red-50 border border-red-200 text-red-700 rounded-lg p-3 mb-4 text-sm">
            <%= alert %>
          </div>
        <% end %>

        <%= form_with url: admin_login_path, method: :post do |f| %>
          <div class="mb-4">
            <%= f.label :username, "Identifiant", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_field :username, autocomplete: "username",
                class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500",
                required: true %>
          </div>

          <div class="mb-6">
            <%= f.label :password, "Mot de passe", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.password_field :password, autocomplete: "current-password",
                class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500",
                required: true %>
          </div>

          <%= f.submit "Se connecter",
              class: "w-full bg-primary-600 hover:bg-primary-700 text-white font-semibold py-2 px-4 rounded-lg transition-colors duration-200" %>
        <% end %>
      </div>
    </div>
  </body>
</html>
