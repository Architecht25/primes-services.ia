<!-- Script de tracking (optionnel) -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  // Tracker les clics vers Ren0vate
  const renovateLinks = document.querySelectorAll('a[href*="renovate.be"]');

  renovateLinks.forEach(link => {
    link.addEventListener('click', function(e) {
      // Tracking optionnel vers votre backend
      fetch('/redirections/track_click', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content
        },
        body: JSON.stringify({
          element: 'renovate_link',
          source: 'renovate_page'
        })
      }).catch(err => console.log('Tracking error:', err));
    });
  });
});
</script>
