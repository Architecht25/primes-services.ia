<div class="bg-gradient-to-r from-pearl-50 to-primary-50 rounded-xl p-8 border border-primary-200">
  <h3 class="text-2xl font-bold text-primary-700 mb-6 text-center">
    📋 Conditions d'éligibilité SWCS
  </h3>

  <div class="grid md:grid-cols-2 gap-6">
    <!-- Conditions personnelles -->
    <div class="bg-white rounded-lg p-6 shadow-sm">
      <h4 class="font-bold text-gray-900 mb-4 flex items-center">
        <span class="text-2xl mr-2">👤</span>
        Conditions personnelles
      </h4>
      <ul class="space-y-2 text-sm text-gray-700">
        <li class="flex items-start">
          <span class="text-primary-600 mr-2">✓</span>
          <div>Minimum 18 ans</div>
        </li>
        <li class="flex items-start">
          <span class="text-primary-600 mr-2">✓</span>
          <div>Personne isolée, famille monoparentale ou classique</div>
        </li>
        <li class="flex items-start">
          <span class="text-primary-600 mr-2">✓</span>
          <div>Maximum 2 enfants ou personnes à charge</div>
        </li>
        <li class="flex items-start">
          <span class="text-primary-600 mr-2">✓</span>
          <div>Revenus stables et capacité de remboursement</div>
        </li>
        <li class="flex items-start">
          <span class="text-primary-600 mr-2">✓</span>
          <div>Remboursement avant 86ème anniversaire</div>
        </li>
      </ul>
    </div>

    <!-- Conditions financières -->
    <div class="bg-white rounded-lg p-6 shadow-sm">
      <h4 class="font-bold text-gray-900 mb-4 flex items-center">
        <span class="text-2xl mr-2">💰</span>
        Conditions financières
      </h4>
      <ul class="space-y-2 text-sm text-gray-700">
        <li class="flex items-start">
          <span class="text-secondary-600 mr-2">✓</span>
          <div><strong>Revenus :</strong> R.I.G. < 122 800€</div>
        </li>
        <li class="flex items-start">
          <span class="text-secondary-600 mr-2">✓</span>
          <div><strong>Montant :</strong> 1 000€ à 60 000€</div>
        </li>
        <li class="flex items-start">
          <span class="text-secondary-600 mr-2">✓</span>
          <div>Taux d'intérêt : 0%</div>
        </li>
        <li class="flex items-start">
          <span class="text-secondary-600 mr-2">✓</span>
          <div>Pas de frais de dossier SWCS</div>
        </li>
      </ul>
    </div>

    <!-- Conditions du logement -->
    <div class="bg-white rounded-lg p-6 shadow-sm">
      <h4 class="font-bold text-gray-900 mb-4 flex items-center">
        <span class="text-2xl mr-2">🏠</span>
        Conditions du logement
      </h4>
      <ul class="space-y-2 text-sm text-gray-700">
        <li class="flex items-start">
          <span class="text-accent-600 mr-2">✓</span>
          <div>Propriétaire du logement en Wallonie</div>
        </li>
        <li class="flex items-start">
          <span class="text-accent-600 mr-2">✓</span>
          <div>Logement de plus de 15 ans</div>
        </li>
        <li class="flex items-start">
          <span class="text-accent-600 mr-2">✓</span>
          <div>Logement salubre ou le sera après travaux</div>
        </li>
        <li class="flex items-start">
          <span class="text-accent-600 mr-2">✓</span>
          <div>Toiture isolée ou le sera après travaux</div>
        </li>
        <li class="flex items-start">
          <span class="text-accent-600 mr-2">✓</span>
          <div>Attestation conformité électrique/gaz valable</div>
        </li>
      </ul>
    </div>

    <!-- Conditions des travaux -->
    <div class="bg-white rounded-lg p-6 shadow-sm">
      <h4 class="font-bold text-gray-900 mb-4 flex items-center">
        <span class="text-2xl mr-2">🔨</span>
        Conditions des travaux
      </h4>
      <ul class="space-y-2 text-sm text-gray-700">
        <li class="flex items-start">
          <span class="text-amber-600 mr-2">✓</span>
          <div>Entrepreneur inscrit Banque-Carrefour</div>
        </li>
        <li class="flex items-start">
          <span class="text-amber-600 mr-2">✓</span>
          <div>Devis et factures conformes</div>
        </li>
        <li class="flex items-start">
          <span class="text-amber-600 mr-2">✓</span>
          <div><strong>Début après</strong> signature acte prêt</div>
        </li>
        <li class="flex items-start">
          <span class="text-amber-600 mr-2">✓</span>
          <div>Travaux conformes normes en vigueur</div>
        </li>
      </ul>
    </div>
  </div>

  <!-- Note famille nombreuse -->
  <div class="mt-6 bg-amber-50 rounded-lg p-4 border border-amber-200">
    <div class="flex items-start space-x-2">
      <span class="text-2xl">👨‍👩‍👧‍👦</span>
      <div class="flex-1">
        <div class="font-semibold text-gray-900 mb-1">Famille nombreuse (+ de 2 enfants) ?</div>
        <div class="text-sm text-gray-700">
          Si vous avez plus de 2 enfants à charge, adressez-vous au <strong>Fonds du Logement des familles nombreuses de Wallonie (FLW)</strong> qui propose des solutions adaptées.
        </div>
        <div class="mt-2">
          <%= link_to "http://www.flw.be/", target: "_blank", rel: "noopener",
              class: "inline-flex items-center text-sm text-primary-600 hover:text-primary-700 font-semibold" do %>
            🔗 www.flw.be
            <svg class="w-3 h-3 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
            </svg>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Contact SWCS -->
  <div class="mt-6 text-center">
    <h4 class="font-bold text-gray-900 mb-3">📞 Contact SWCS</h4>
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center text-sm text-gray-700">
      <div>
        <strong>Téléphone :</strong>
        <a href="tel:078158008" class="text-primary-600 hover:text-primary-700 font-semibold">078/158.008</a>
      </div>
      <div>
        <strong>Email :</strong>
        <a href="mailto:contact@swcs.be" class="text-primary-600 hover:text-primary-700 font-semibold">contact@swcs.be</a>
      </div>
      <div>
        <strong>Adresse :</strong> Rue de l'Ecluse 10, 6000 Charleroi
      </div>
    </div>
  </div>
</div>
