<% content_for :title, "Simulation de Primes et Prêts - Calculez vos aides financières" %>
<% content_for :description, "Simulez vos primes de rénovation et prêts à taux 0% ou taux réduits en Belgique. Calculateur instantané pour Wallonie, Flandre et Bruxelles." %>
<% content_for :keywords, "simulation primes belgique, calculateur subsides, prêt taux zéro, prêt vert, primes rénovation" %>

<!-- Section Hero -->
<section class="bg-gradient-to-br from-primary-600 to-primary-800 text-white py-16 lg:py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <h1 class="text-4xl lg:text-5xl font-bold leading-tight mb-6">
        Simulateur de Primes et Prêts
      </h1>
      <p class="text-xl lg:text-2xl mb-8 text-primary-100">
        Calculez instantanément vos aides financières : <strong>primes + prêts à taux 0% ou réduits</strong>
      </p>

      <!-- Statistiques -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        <div class="bg-white/10 rounded-lg p-6 backdrop-blur-sm border border-white/20">
          <div class="text-3xl font-bold text-amber-400">15 000€</div>
          <div class="text-sm text-primary-100">Prime max Wallonie</div>
        </div>
        <div class="bg-white/10 rounded-lg p-6 backdrop-blur-sm border border-white/20">
          <div class="text-3xl font-bold text-amber-400">8 000€</div>
          <div class="text-sm text-primary-100">Prime moyenne Flandre</div>
        </div>
        <div class="bg-white/10 rounded-lg p-6 backdrop-blur-sm border border-white/20">
          <div class="text-3xl font-bold text-amber-400">0%</div>
          <div class="text-sm text-primary-100">Prêt vert disponible</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Sélection de région -->
<section class="py-16 bg-pearl-50">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl lg:text-4xl font-bold text-primary-700 mb-4">
        Choisissez votre région
      </h2>
      <p class="text-xl text-gray-600">
        Les primes et prêts varient selon votre région en Belgique
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      <!-- Wallonie -->
      <a href="<%= simulation_region_path('wallonie') %>"
         data-controller="scroll-animation" data-scroll-animation-delay-value="0"
         class="group bg-white rounded-2xl p-8 hover:shadow-2xl transition-all duration-300 transform hover:scale-105 cursor-pointer border-2 border-pearl-200 hover:border-primary-400">
        <div class="text-center">
          <div class="w-20 h-20 bg-primary-600 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform shadow-lg">
            <!-- Coq wallon stylisé -->
            <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-10 h-10">
              <rect width="40" height="40" rx="20" fill="#CC0000"/>
              <text x="20" y="26" text-anchor="middle" font-size="18" fill="#FFD700" font-family="serif" font-weight="bold">W</text>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-primary-700 mb-3">Wallonie</h3>
          <p class="text-gray-600 mb-2">Primes Habitation, Rénopack, prêts verts</p>
          <p class="text-sm text-primary-600 font-semibold mb-6">Jusqu'à 15 000 € de primes</p>
          <div class="bg-primary-600 text-white px-6 py-3 rounded-lg font-semibold group-hover:bg-primary-700 transition-colors shadow-md">
            Simuler en Wallonie →
          </div>
        </div>
      </a>

      <!-- Flandre -->
      <a href="<%= simulation_region_path('flandre') %>"
         data-controller="scroll-animation" data-scroll-animation-delay-value="100"
         class="group bg-white rounded-2xl p-8 hover:shadow-2xl transition-all duration-300 transform hover:scale-105 cursor-pointer border-2 border-pearl-200 hover:border-secondary-400">
        <div class="text-center">
          <div class="w-20 h-20 bg-secondary-500 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform shadow-lg">
            <!-- Lion flamand stylisé -->
            <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-10 h-10">
              <rect width="40" height="40" rx="20" fill="#FFD700"/>
              <text x="20" y="26" text-anchor="middle" font-size="18" fill="#1a1a1a" font-family="serif" font-weight="bold">F</text>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-secondary-600 mb-3">Flandre</h3>
          <p class="text-gray-600 mb-2">Mijn VerbouwPremie, prêts rénovation</p>
          <p class="text-sm text-secondary-600 font-semibold mb-6">Jusqu'à 8 000 € de primes</p>
          <div class="bg-secondary-500 text-white px-6 py-3 rounded-lg font-semibold group-hover:bg-secondary-600 transition-colors shadow-md">
            Simuler en Flandre →
          </div>
        </div>
      </a>

      <!-- Bruxelles -->
      <a href="<%= simulation_region_path('bruxelles') %>"
         data-controller="scroll-animation" data-scroll-animation-delay-value="200"
         class="group bg-white rounded-2xl p-8 hover:shadow-2xl transition-all duration-300 transform hover:scale-105 cursor-pointer border-2 border-pearl-200 hover:border-accent-400">
        <div class="text-center">
          <div class="w-20 h-20 bg-accent-400 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform shadow-lg">
            <!-- Iris bruxellois stylisé -->
            <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-10 h-10">
              <rect width="40" height="40" rx="20" fill="#1a3c8f"/>
              <text x="20" y="26" text-anchor="middle" font-size="18" fill="#FFD700" font-family="serif" font-weight="bold">B</text>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-accent-500 mb-3">Bruxelles</h3>
          <p class="text-gray-600 mb-2">Renolution, Ecoreno, prêts verts</p>
          <p class="text-sm text-accent-500 font-semibold mb-6">Jusqu'à 100 000 € de primes</p>
          <div class="bg-accent-400 text-white px-6 py-3 rounded-lg font-semibold group-hover:bg-accent-500 transition-colors shadow-md">
            Simuler à Bruxelles →
          </div>
        </div>
      </a>
    </div>
  </div>
</section>

<!-- Pourquoi simuler -->
<section class="py-16 bg-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-primary-700 mb-4">
        Pourquoi utiliser notre simulateur ?
      </h2>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      <div class="bg-white rounded-xl p-6 shadow-lg border-t-4 border-secondary-500">
        <div class="text-4xl mb-4">🎯</div>
        <h3 class="text-xl font-bold text-primary-700 mb-3">Précision maximale</h3>
        <p class="text-gray-600">
          Calculs basés sur les barèmes officiels 2026 de chaque région
        </p>
      </div>

      <div class="bg-white rounded-xl p-6 shadow-lg border-t-4 border-accent-400">
        <div class="text-4xl mb-4">⚡</div>
        <h3 class="text-xl font-bold text-primary-700 mb-3">Résultats instantanés</h3>
        <p class="text-gray-600">
          Obtenez une estimation en quelques secondes seulement
        </p>
      </div>

      <div class="bg-white rounded-xl p-6 shadow-lg border-t-4 border-amber-400">
        <div class="text-4xl mb-4">💡</div>
        <h3 class="text-xl font-bold text-primary-700 mb-3">Primes + Prêts</h3>
        <p class="text-gray-600">
          Simulez à la fois les primes directes et les prêts à taux avantageux
        </p>
      </div>

      <div class="bg-white rounded-xl p-6 shadow-lg border-t-4 border-primary-400">
        <div class="text-4xl mb-4">🆓</div>
        <h3 class="text-xl font-bold text-primary-700 mb-3">100% gratuit</h3>
        <p class="text-gray-600">
          Utilisez le simulateur autant de fois que vous le souhaitez
        </p>
      </div>
    </div>
  </div>
</section>

<!-- CTA double : Ren0vate + IA -->
<section class="py-16 bg-gradient-to-br from-primary-800 to-primary-900 text-white">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10">
      <h2 class="text-3xl lg:text-4xl font-bold mb-4">
        Simulation faite — et maintenant ?
      </h2>
      <p class="text-xl text-primary-200">
        Nos experts transforment vos simulations en dossiers réels approuvés.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      <!-- CTA Ren0vate — principal -->
      <div data-controller="scroll-animation" data-scroll-animation-delay-value="0"
           class="bg-white/10 border border-white/20 rounded-2xl p-8 text-center hover:bg-white/15 transition-colors">
        <div class="text-4xl mb-4">🏠</div>
        <h3 class="text-2xl font-bold mb-3">Passer à l'action</h3>
        <p class="text-primary-200 mb-6">
          Ren0vate gère votre dossier complet — de la demande à l'encaissement de vos primes.
        </p>
        <div class="flex items-center justify-center gap-2 text-sm text-primary-300 mb-6">
          <span>✓ Dossier pré-rempli</span>
          <span>•</span>
          <span>✓ Suivi en temps réel</span>
          <span>•</span>
          <span>✓ Sans effort</span>
        </div>
        <%= link_to renovate_path,
            class: "inline-block bg-amber-400 text-primary-900 px-8 py-4 rounded-xl font-bold text-lg hover:bg-amber-300 transition-colors shadow-lg w-full text-center" do %>
          Démarrer mon dossier sur Ren0vate →
        <% end %>
      </div>

      <!-- CTA IA — secondaire -->
      <div data-controller="scroll-animation" data-scroll-animation-delay-value="150"
           class="bg-white/5 border border-white/10 rounded-2xl p-8 text-center hover:bg-white/10 transition-colors">
        <div class="text-4xl mb-4">🤖</div>
        <h3 class="text-2xl font-bold mb-3">Des questions ?</h3>
        <p class="text-primary-200 mb-6">
          Notre IA répond en 30 secondes à toutes vos questions sur les primes et prêts à taux 0%.
        </p>
        <div class="flex items-center justify-center gap-2 text-sm text-primary-300 mb-6">
          <span>✓ Disponible 24h/24</span>
          <span>•</span>
          <span>✓ 324 subsides référencés</span>
        </div>
        <%= link_to ai_chat_path,
            class: "inline-block bg-white/20 text-white px-8 py-4 rounded-xl font-semibold text-lg hover:bg-white/30 transition-colors w-full text-center" do %>
          💬 Parler avec l'assistant IA
        <% end %>
      </div>
    </div>
  </div>
</section>
