<% content_for :title, "Simulation de Primes et Prêts - Calculez vos aides financières" %>
<% content_for :description, "Simulez vos primes de rénovation et prêts à taux 0% ou taux réduits en Belgique. Calculateur instantané pour Wallonie, Flandre et Bruxelles." %>
<% content_for :keywords, "simulation primes belgique, calculateur subsides, prêt taux zéro, prêt vert, primes rénovation" %>

<!-- Section Hero -->
<section class="bg-gradient-to-br from-green-600 via-blue-600 to-purple-600 text-white py-16 lg:py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <h1 class="text-4xl lg:text-5xl font-bold leading-tight mb-6">
        Simulateur de Primes et Prêts
      </h1>
      <p class="text-xl lg:text-2xl mb-8 text-blue-100">
        Calculez instantanément vos aides financières : <strong>primes + prêts à taux 0% ou réduits</strong>
      </p>

      <!-- Statistiques -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        <div class="bg-white/10 rounded-lg p-6 backdrop-blur-sm">
          <div class="text-3xl font-bold text-yellow-300">15 000€</div>
          <div class="text-sm text-blue-100">Prime max Wallonie</div>
        </div>
        <div class="bg-white/10 rounded-lg p-6 backdrop-blur-sm">
          <div class="text-3xl font-bold text-yellow-300">35 000€</div>
          <div class="text-sm text-blue-100">Prime max Bruxelles</div>
        </div>
        <div class="bg-white/10 rounded-lg p-6 backdrop-blur-sm">
          <div class="text-3xl font-bold text-yellow-300">0%</div>
          <div class="text-sm text-blue-100">Prêt vert disponible</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Sélection de région -->
<section class="py-16 bg-white">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
        Choisissez votre région
      </h2>
      <p class="text-xl text-gray-600">
        Les primes et prêts varient selon votre région en Belgique
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      <!-- Wallonie -->
      <a href="<%= simulation_region_path('wallonie') %>"
         class="group bg-gradient-to-br from-blue-50 to-blue-100 rounded-2xl p-8 hover:shadow-2xl transition-all duration-300 transform hover:scale-105 cursor-pointer border-2 border-transparent hover:border-blue-500">
        <div class="text-center">
          <div class="w-20 h-20 bg-blue-600 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform">
            <span class="text-white text-3xl">🟦</span>
          </div>
          <h3 class="text-2xl font-bold text-blue-900 mb-3">Wallonie</h3>
          <p class="text-blue-700 mb-6">
            Primes Habitation, Rénopack, prêts verts Wallonie
          </p>
          <div class="bg-blue-600 text-white px-6 py-3 rounded-lg font-semibold group-hover:bg-blue-700 transition-colors">
            Simuler en Wallonie →
          </div>
        </div>
      </a>

      <!-- Flandre -->
      <a href="<%= simulation_region_path('flandre') %>"
         class="group bg-gradient-to-br from-orange-50 to-orange-100 rounded-2xl p-8 hover:shadow-2xl transition-all duration-300 transform hover:scale-105 cursor-pointer border-2 border-transparent hover:border-orange-500">
        <div class="text-center">
          <div class="w-20 h-20 bg-orange-600 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform">
            <span class="text-white text-3xl">🟧</span>
          </div>
          <h3 class="text-2xl font-bold text-orange-900 mb-3">Flandre</h3>
          <p class="text-orange-700 mb-6">
            Mijn VerbouwPremie, prêts rénovation Flandre
          </p>
          <div class="bg-orange-600 text-white px-6 py-3 rounded-lg font-semibold group-hover:bg-orange-700 transition-colors">
            Simuler en Flandre →
          </div>
        </div>
      </a>

      <!-- Bruxelles -->
      <a href="<%= simulation_region_path('bruxelles') %>"
         class="group bg-gradient-to-br from-green-50 to-green-100 rounded-2xl p-8 hover:shadow-2xl transition-all duration-300 transform hover:scale-105 cursor-pointer border-2 border-transparent hover:border-green-500">
        <div class="text-center">
          <div class="w-20 h-20 bg-green-600 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform">
            <span class="text-white text-3xl">🟩</span>
          </div>
          <h3 class="text-2xl font-bold text-green-900 mb-3">Bruxelles</h3>
          <p class="text-green-700 mb-6">
            Renolution, prêts verts Bruxellois
          </p>
          <div class="bg-green-600 text-white px-6 py-3 rounded-lg font-semibold group-hover:bg-green-700 transition-colors">
            Simuler à Bruxelles →
          </div>
        </div>
      </a>
    </div>
  </div>
</section>

<!-- Pourquoi simuler -->
<section class="py-16 bg-gray-50">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-gray-900 mb-4">
        Pourquoi utiliser notre simulateur ?
      </h2>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      <div class="bg-white rounded-xl p-6 shadow-lg">
        <div class="text-4xl mb-4">🎯</div>
        <h3 class="text-xl font-bold text-gray-900 mb-3">Précision maximale</h3>
        <p class="text-gray-600">
          Calculs basés sur les barèmes officiels 2026 de chaque région
        </p>
      </div>

      <div class="bg-white rounded-xl p-6 shadow-lg">
        <div class="text-4xl mb-4">⚡</div>
        <h3 class="text-xl font-bold text-gray-900 mb-3">Résultats instantanés</h3>
        <p class="text-gray-600">
          Obtenez une estimation en quelques secondes seulement
        </p>
      </div>

      <div class="bg-white rounded-xl p-6 shadow-lg">
        <div class="text-4xl mb-4">💡</div>
        <h3 class="text-xl font-bold text-gray-900 mb-3">Primes + Prêts</h3>
        <p class="text-gray-600">
          Simulez à la fois les primes directes et les prêts à taux avantageux
        </p>
      </div>

      <div class="bg-white rounded-xl p-6 shadow-lg">
        <div class="text-4xl mb-4">🆓</div>
        <h3 class="text-xl font-bold text-gray-900 mb-3">100% gratuit</h3>
        <p class="text-gray-600">
          Utilisez le simulateur autant de fois que vous le souhaitez
        </p>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="py-12 bg-gradient-to-r from-blue-600 to-green-600 text-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl font-bold mb-4">
      Besoin d'aide personnalisée ?
    </h2>
    <p class="text-xl mb-8 text-blue-100">
      Notre assistant IA peut répondre à toutes vos questions
    </p>

    <%= link_to ai_chat_path,
        class: "inline-block bg-white text-blue-600 px-8 py-4 rounded-lg font-bold text-lg hover:bg-blue-50 transition-colors shadow-lg" do %>
      💬 Parler avec l'IA
    <% end %>
  </div>
</section>
