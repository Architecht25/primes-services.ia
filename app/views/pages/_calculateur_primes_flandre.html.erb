<div class="bg-gradient-to-br from-primary-50 to-primary-100 rounded-xl shadow-lg p-6 lg:p-8 border border-primary-200 hover:shadow-xl transition-shadow">
  <div class="flex items-start space-x-4">
    <div class="flex-shrink-0 w-16 h-16 bg-primary-600 rounded-full flex items-center justify-center text-3xl">
      🧮
    </div>
    <div class="flex-1">
      <h3 class="text-2xl font-bold text-gray-900 mb-3">
        Calculateur de Primes Flandre
      </h3>
      <p class="text-gray-700 mb-4">
        Bereken onmiddellijk het geschatte bedrag van de premies waarvoor u in aanmerking komt op basis van uw inkomen en uw energierenovatiewerken.
      </p>

      <div class="grid md:grid-cols-2 gap-4 mb-4">
        <div class="bg-white rounded-lg p-4">
          <div class="text-sm font-semibold text-primary-900 mb-1">💰 Maximum bedrag</div>
          <div class="text-lg font-bold text-primary-700">Tot 12 000€</div>
          <div class="text-sm text-gray-600">volgens inkomen en werken</div>
        </div>
        <div class="bg-white rounded-lg p-4">
          <div class="text-sm font-semibold text-primary-900 mb-1">⚡ Resultaat</div>
          <div class="text-sm text-gray-700">Direct en gepersonaliseerd</div>
        </div>
      </div>

      <div class="bg-white rounded-lg p-4 mb-4">
        <h4 class="font-semibold text-gray-900 mb-2">✓ De calculator houdt rekening met:</h4>
        <ul class="space-y-1 text-sm text-gray-700">
          <li>• Uw jaarlijks gezinsinkomen</li>
          <li>• De geplande soorten werken (isolatie, verwarming, ventilatie...)</li>
          <li>• Uw totale renovatiebudget</li>
          <li>• De officiële plafonds en barema's 2026</li>
          <li>• De verhogingen volgens uw inkomstencategorie</li>
        </ul>
      </div>

      <div class="bg-white rounded-lg p-4 mb-4">
        <h4 class="font-semibold text-gray-900 mb-3">📊 In aanmerking komende werken:</h4>
        <div class="grid grid-cols-2 gap-2 text-sm text-gray-700">
          <div>• Dakisolatie</div>
          <div>• Muurisolatie</div>
          <div>• Warmtepomp</div>
          <div>• Hoogrendementketel</div>
          <div>• Zonneboiler</div>
          <div>• Zonnepanelen</div>
          <div>• Dubbele flux ventilatie</div>
          <div>• En meer...</div>
        </div>
      </div>

      <div class="bg-amber-50 rounded-lg p-4 mb-4 border border-amber-200">
        <div class="flex items-start space-x-2">
          <span class="text-xl">💡</span>
          <div class="text-sm text-gray-700">
            <strong>Tip:</strong> Het resultaat is een indicatieve schatting. Voor een exacte en gepersonaliseerde berekening,
            raadpleeg onze AI-assistent of onze experts die uw volledige dossier zullen analyseren.
          </div>
        </div>
      </div>

      <div class="flex flex-wrap gap-3">
        <%= link_to "https://www.vlaanderen.be/premies-voor-verbouwingen", target: "_blank", rel: "noopener",
            class: "inline-flex items-center px-5 py-3 bg-primary-600 text-white font-semibold rounded-lg hover:bg-primary-700 transition-colors shadow-md" do %>
          📖 Meer informatie
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
          </svg>
        <% end %>
        <%= link_to ai_chat_path,
            class: "inline-flex items-center px-5 py-3 bg-white text-primary-600 font-semibold rounded-lg hover:bg-primary-50 transition-colors border border-primary-300" do %>
          💬 Vraag stellen
        <% end %>
      </div>
    </div>
  </div>
</div>
