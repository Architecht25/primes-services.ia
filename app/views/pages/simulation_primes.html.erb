<%
  region_config = {
    'wallonie' => { name: 'Wallonie', color: 'primary', icon: '🟦',
                    hero_bg: 'bg-gradient-to-br from-primary-600 to-primary-800',
                    text_light: 'text-white/90',
                    link_color: 'text-white/90 hover:text-white' },
    'flandre' => { name: 'Flandre', color: 'secondary', icon: '🟧',
                   hero_bg: 'bg-gradient-to-br from-primary-600 to-primary-800',
                   text_light: 'text-white/90',
                   link_color: 'text-white/90 hover:text-white' },
    'bruxelles' => { name: 'Bruxelles', color: 'accent', icon: '🟩',
                     hero_bg: 'bg-gradient-to-br from-primary-600 to-primary-800',
                     text_light: 'text-white/90',
                     link_color: 'text-white/90 hover:text-white' }
  }
  config = region_config[@region] || region_config['wallonie']

  # Classes CSS selon la région
  input_focus = @region == 'wallonie' ? 'focus:ring-primary-500 focus:border-primary-500' :
                @region == 'flandre' ? 'focus:ring-secondary-500 focus:border-secondary-500' :
                'focus:ring-accent-500 focus:border-accent-500'

  checkbox_color = @region == 'wallonie' ? 'text-primary-600 focus:ring-primary-500' :
                   @region == 'flandre' ? 'text-secondary-500 focus:ring-secondary-500' :
                   'text-accent-400 focus:ring-accent-500'

  btn_gradient = 'bg-gradient-to-r from-primary-600 to-secondary-600 hover:from-primary-700 hover:to-secondary-700'

  results_bg = 'bg-gradient-to-r from-accent-50 to-secondary-50'

  cta_bg = 'bg-gradient-to-r from-primary-600 to-secondary-600'

  cta_btn_white = 'bg-amber-400 text-primary-900 hover:bg-amber-500'

  cta_btn_light = 'bg-white text-primary-700 hover:bg-pearl-50'
%>

<% content_for :title, "Simulation Primes #{config[:name]} - Calculez vos aides" %>
<% content_for :description, "Simulateur de primes de rénovation pour la #{config[:name]}. Calcul instantané selon vos revenus et travaux." %>

<!-- Hero -->
<section class="<%= config[:hero_bg] %> text-white py-16">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class="mb-4">
      <%= link_to simulation_region_path(@region), class: "#{config[:link_color]} text-sm" do %>
        ← Retour
      <% end %>
    </div>

    <div class="text-5xl mb-4"><%= config[:icon] %></div>

    <h1 class="text-4xl lg:text-5xl font-bold mb-6">
      Simulation Primes - <%= config[:name] %>
    </h1>

    <p class="text-xl <%= config[:text_light] %>">
      Calculez instantanément le montant des primes auxquelles vous avez droit
    </p>
  </div>
</section>

<% if @region == 'wallonie' %>
<!-- Primes spécifiques Wallonie -->
<section class="py-12 bg-pearl-50">
  <div class="max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10">
      <h2 class="text-3xl lg:text-4xl font-bold text-primary-700 mb-4">
        Primes et outils disponibles en Wallonie
      </h2>
      <p class="text-lg text-gray-600">
        Découvrez les primes adaptées à votre situation
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <!-- Calculateur de Primes Wallonie -->
      <%= render partial: 'pages/calculateur_primes_wallonie' %>

      <!-- Prime Audit -->
      <%= render partial: 'pages/prime_audit' %>

      <!-- Prime Monuments et Sites -->
      <%= render partial: 'pages/prime_monuments_sites' %>

      <!-- Primes Communales -->
      <%= render partial: 'pages/primes_communales' %>
    </div>
  </div>
</section>
<% end %>

<% if @region == 'flandre' %>
<!-- Primes spécifiques Flandre -->
<section class="py-12 bg-pearl-50">
  <div class="max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10">
      <h2 class="text-3xl lg:text-4xl font-bold text-primary-700 mb-4">
        Primes et outils disponibles en Flandre
      </h2>
      <p class="text-lg text-gray-600">
        Découvrez les primes adaptées à votre situation
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <!-- Calculateur de Primes Flandre -->
      <%= render partial: 'pages/calculateur_primes_flandre' %>

      <!-- Prime PEB -->
      <%= render partial: 'pages/prime_peb' %>

      <!-- Prime Monuments et Sites -->
      <%= render partial: 'pages/prime_monuments_sites_flandre' %>

      <!-- Primes Communales -->
      <%= render partial: 'pages/primes_communales_flandre' %>
    </div>
  </div>
</section>
<% end %>

<% if @region == 'bruxelles' %>
<!-- Primes spécifiques Bruxelles -->
<section class="py-12 bg-pearl-50">
  <div class="max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10">
      <h2 class="text-3xl lg:text-4xl font-bold text-primary-700 mb-4">
        Primes et outils disponibles à Bruxelles
      </h2>
      <p class="text-lg text-gray-600">
        Découvrez les primes adaptées à votre situation
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <!-- Calculateur de Primes Bruxelles -->
      <%= render partial: 'pages/calculateur_primes_bruxelles' %>

      <!-- Prime Petit Patrimoine -->
      <%= render partial: 'pages/prime_petit_patrimoine' %>

      <!-- Prime Monuments et Sites -->
      <%= render partial: 'pages/prime_monuments_sites_bruxelles' %>

      <!-- Primes Communales -->
      <%= render partial: 'pages/primes_communales_bruxelles' %>
    </div>

    <!-- CTA vers assistant IA -->
    <div class="mt-12 text-center">
      <div class="bg-gradient-to-r from-accent-50 to-secondary-50 rounded-xl p-8 border border-accent-200">
        <h3 class="text-2xl font-bold text-primary-700 mb-3">
          💬 Besoin d'aide pour votre projet ?
        </h3>
        <p class="text-gray-700 mb-6">
          Notre assistant IA peut vous aider à identifier toutes les primes auxquelles vous avez droit et vous accompagner dans vos démarches.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <%= link_to ai_chat_path,
              class: "inline-flex items-center justify-center px-8 py-4 bg-secondary-500 text-white font-bold text-lg rounded-lg hover:bg-secondary-600 transition-colors shadow-lg" do %>
            💬 Discuter avec l'assistant IA
          <% end %>
          <%= link_to simulation_prets_path(@region),
              class: "inline-flex items-center justify-center px-8 py-4 bg-white text-primary-700 font-bold text-lg rounded-lg hover:bg-pearl-50 transition-colors border-2 border-primary-400" do %>
            🏦 Découvrir les prêts disponibles
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>
<% end %>
