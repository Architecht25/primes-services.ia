  <!-- Conditions générales -->
  <div class="grid md:grid-cols-2 gap-4 mb-6">
    <div class="bg-white rounded-lg p-4 border border-gray-200">
      <h4 class="font-semibold text-gray-900 mb-3 flex items-center">
        <span class="mr-2">✅</span> Qui peut emprunter ?
      </h4>
      <ul class="space-y-1 text-sm text-gray-700">
        <li>• <strong>Résider</strong> ou <strong>domicilier</strong> en Région bruxelloise</li>
        <li>• Le bien doit être situé dans les <strong>19 communes</strong> de Bruxelles-Capitale</li>
        <li>• Respecter les plafonds de revenus</li>
        <li>• Remboursement avant <strong>70 ans</strong> du plus jeune emprunteur</li>
        <li>• Justifier d'une <strong>capacité financière</strong> suffisante</li>
      </ul>
    </div>

    <div class="bg-white rounded-lg p-4 border border-gray-200">
      <h4 class="font-semibold text-gray-900 mb-3 flex items-center">
        <span class="mr-2">🏠</span> Conditions du logement
      </h4>
      <ul class="space-y-1 text-sm text-gray-700">
        <li>• Situé dans une des <strong>19 communes</strong> bruxelloises</li>
        <li>• Logement <strong>existant</strong> (pas de construction neuve)</li>
        <li>• Destination : habitation privée</li>
        <li>• Pas de limites d'âge du logement</li>
        <li>• Conforme aux normes de sécurité et salubrité</li>
      </ul>
    </div>

    <div class="bg-white rounded-lg p-4 border border-gray-200">
      <h4 class="font-semibold text-gray-900 mb-3 flex items-center">
        <span class="mr-2">🔧</span> Travaux éligibles
      </h4>
      <ul class="space-y-1 text-sm text-gray-700">
        <li>• <strong>Priorité :</strong> rénovation énergétique</li>
        <li>• Travaux d'<strong>économie d'énergie</strong></li>
        <li>• Travaux d'<strong>autonomie</strong> (PMR, seniors)</li>
        <li>• Travaux de <strong>sécurité</strong> et <strong>salubrité</strong></li>
        <li>• Rénovation classique : électricité, toiture, sanitaire...</li>
        <li>• Nécessitent devis préalable et factures</li>
      </ul>
    </div>

    <div class="bg-white rounded-lg p-4 border border-gray-200">
      <h4 class="font-semibold text-gray-900 mb-3 flex items-center">
        <span class="mr-2">📝</span> Modalités pratiques
      </h4>
      <ul class="space-y-1 text-sm text-gray-700">
        <li>• Mensualité <strong>minimum : 25€</strong></li>
        <li>• Paiement direct sur <strong>factures</strong></li>
        <li>• Délai moyen RDV : <strong>3 semaines</strong></li>
        <li>• Accompagnement par <strong>Homegrade</strong> ou <strong>Réseau Habitat</strong></li>
        <li>• Assurance incendie obligatoire</li>
      </ul>
    </div>
