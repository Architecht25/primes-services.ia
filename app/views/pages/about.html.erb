          </div>
          <h3 class="text-2xl font-bold text-red-400">ChatGPT / IA Généraliste</h3>
        </div>

        <ul class="space-y-3">
          <li class="flex items-start">
            <span class="text-red-400 mr-3">❌</span>
            <span>Connaissance générale, pas spécialisée Belgique</span>
          </li>
          <li class="flex items-start">
            <span class="text-red-400 mr-3">❌</span>
            <span>Informations parfois obsolètes ou inexactes</span>
          </li>
          <li class="flex items-start">
            <span class="text-red-400 mr-3">❌</span>
            <span>Pas de mise à jour réglementaire en temps réel</span>
          </li>
          <li class="flex items-start">
            <span class="text-red-400 mr-3">❌</span>
            <span>Calculs approximatifs ou erronés</span>
          </li>
          <li class="flex items-start">
            <span class="text-red-400 mr-3">❌</span>
            <span>Aucun accompagnement humain personnalisé</span>
          </li>
          <li class="flex items-start">
            <span class="text-red-400 mr-3">❌</span>
            <span>Information seulement, pas d'action concrète</span>
          </li>
          <li class="flex items-start">
            <span class="text-red-400 mr-3">❌</span>
            <span>Pas de garantie de résultat</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="text-center mt-12">
      <%= link_to ai_chat_path,
