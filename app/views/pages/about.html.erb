<!-- Nos Conseils en Rénovation -->
<section class="py-16 bg-gradient-to-br from-green-50 to-blue-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
