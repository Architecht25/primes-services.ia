<%
  region_config = {
    'wallonie' => {
      name: 'Wallonie',
      icon: '🟦',
      prets: [
        { nom: 'Prêt Vert Wallon', taux: '0% à 2%', montant: '60 000€', duree: '5-30 ans', url: 'https://www.lcl.be' },
        { nom: 'Prêt Habitation Wallonie', taux: '1% à 3%', montant: '50 000€', duree: '10-25 ans', url: '#' }
      ]
    },
    'flandre' => {
      name: 'Flandre',
      icon: '🟧',
      prets: [
        { nom: 'Prêt Rénovation Flamand', taux: '1% à 3%', montant: '50 000€', duree: '5-25 ans', url: 'https://www.vlaanderen.be/energielening' },
        { nom: 'Energielening', taux: '0% à 2%', montant: '40 000€', duree: '10-20 ans', url: '#' }
      ]
    },
    'bruxelles' => {
      name: 'Bruxelles',
      icon: '🟩',
      prets: [
        { nom: 'Prêt Vert Bruxellois', taux: '0% à 2%', montant: '25 000€', duree: '5-15 ans', url: 'https://www.flw.brussels/' },
        { nom: 'Prêt Renolution', taux: '1% à 3%', montant: '30 000€', duree: '10-20 ans', url: '#' }
      ]
    }
  }
  config = region_config[@region] || region_config['wallonie']

  # Classes CSS selon région
  card_bg = 'bg-gradient-to-br from-amber-50 to-amber-100'
  badge_bg = 'bg-amber-400'
  title_color = 'text-amber-600'
  btn_bg = 'bg-amber-400'
  btn_hover = 'hover:bg-amber-500'
  focus_ring = 'focus:ring-amber-400 focus:border-amber-400'
%>

<% content_for :title, "Prêts à Taux 0% #{config[:name]} - Financez vos travaux" %>
<% content_for :description, "Découvrez les prêts verts et solutions de financement à taux avantageux en #{config[:name]}." %>

<!-- Hero -->
<section class="bg-gradient-to-br from-primary-600 to-primary-800 text-white py-16">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class="mb-4">
      <%= link_to simulation_region_path(@region), class: "text-white/90 hover:text-white text-sm" do %>
        ← Retour
      <% end %>
    </div>

    <div class="text-5xl mb-4">🏦</div>

    <h1 class="text-4xl lg:text-5xl font-bold mb-6">
      Prêts à Taux 0% - <%= config[:name] %>
    </h1>

    <p class="text-xl text-white/90">
      Solutions de financement avantageuses pour vos travaux de rénovation
    </p>
  </div>
</section>

<% if @region == 'wallonie' %>
<!-- Prêts spécifiques Wallonie - SWCS -->
<section class="py-12 bg-pearl-50">
  <div class="max-w-[95%] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10">
      <h2 class="text-3xl lg:text-4xl font-bold text-primary-700 mb-4">
        Prêts à Taux 0% - Société Wallonne du Crédit Social
      </h2>
      <p class="text-lg text-gray-600">
        3 formules de prêts sans intérêts pour financer vos travaux de rénovation
      </p>
    </div>

    <!-- Grille des 3 prêts -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-12">
      <!-- Rénopack -->
      <%= render partial: 'pages/pret_renopack' %>

      <!-- Rénopack SWCS -->
      <%= render partial: 'pages/pret_renopack_swcs' %>

      <!-- Rénoprêt -->
      <%= render partial: 'pages/pret_renopret' %>
    </div>

    <!-- Conditions communes -->
    <%= render partial: 'pages/pret_conditions_swcs' %>
  </div>
</section>
<% elsif @region == 'flandre' %>
<!-- Prêts spécifiques Flandre - Mijn VerbouwLening -->
<section class="py-12 bg-pearl-50">
  <div class="max-w-[95%] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10">
      <h2 class="text-3xl lg:text-4xl font-bold text-primary-700 mb-4">
        Mijn VerbouwLening - Prêt Rénovation à Taux Réduit
      </h2>
      <p class="text-lg text-gray-600">
        Financez vos travaux avec un taux variable selon vos revenus - Nouveautés 2026
      </p>
    </div>

    <!-- Grille 2 colonnes -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- Mijn VerbouwLening -->
      <div>
        <%= render partial: 'pages/pret_mijn_verbouwlening' %>
      </div>

      <!-- Conditions -->
      <div>
        <%= render partial: 'pages/pret_conditions_mijn_verbouwlening' %>
      </div>
    </div>
  </div>
</section>
<% elsif @region == 'bruxelles' %>
<!-- Prêts spécifiques Bruxelles - Crédit EcoRéno -->
<section class="py-12 bg-pearl-50">
  <div class="max-w-[95%] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10">
      <h2 class="text-3xl lg:text-4xl font-bold text-primary-700 mb-4">
        Crédit EcoRéno - Fonds du Logement de Bruxelles
      </h2>
      <p class="text-lg text-gray-600">
        2 formules de financement à taux réduit pour vos travaux de rénovation et d'économie d'énergie
      </p>
    </div>

    <!-- Grille 3 colonnes -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- Crédit Hypothécaire -->
      <%= render partial: 'pages/pret_ecoreno_hypothecaire' %>

      <!-- Crédit Consommation -->
      <%= render partial: 'pages/pret_ecoreno_consommation' %>

      <!-- Conditions communes -->
      <%= render partial: 'pages/pret_conditions_ecoreno' %>
    </div>
  </div>
</section>
<% else %>
<!-- Prêts disponibles - Fallback générique -->
<section class="py-12 bg-pearl-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-primary-700 mb-4">
        Prêts disponibles en <%= config[:name] %>
      </h2>
      <p class="text-xl text-gray-600">
        Financez vos travaux avec des taux avantageux
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      <% config[:prets].each_with_index do |pret, index| %>
        <div class="<%= card_bg %> rounded-xl shadow-lg p-8 border border-amber-200">
          <div class="flex items-center mb-4">
            <div class="w-12 h-12 <%= badge_bg %> rounded-full flex items-center justify-center text-white text-2xl mr-4 shadow-md">
              <%= index + 1 %>
            </div>
            <h3 class="text-2xl font-bold <%= title_color %>"><%= pret[:nom] %></h3>
          </div>

          <div class="space-y-3 text-gray-700 mb-6">
            <p><strong>Taux :</strong> <%= pret[:taux] %></p>
            <p><strong>Montant max :</strong> Jusqu'à <%= pret[:montant] %></p>
            <p><strong>Durée :</strong> <%= pret[:duree] %></p>
          </div>

          <% if pret[:url] != '#' %>
            <a href="<%= pret[:url] %>"
               target="_blank" rel="noopener"
               class="block text-center <%= btn_bg %> text-white px-6 py-3 rounded-lg font-semibold <%= btn_hover %> transition-colors shadow-md">
              En savoir plus →
            </a>
          <% else %>
            <button class="w-full <%= btn_bg %> text-white px-6 py-3 rounded-lg font-semibold <%= btn_hover %> transition-colors shadow-md">
              Demander une simulation
            </button>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</section>
<% end %>

<!-- Simulateur simple -->
<section class="py-12 bg-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-white rounded-2xl shadow-xl p-8 border-t-4 border-amber-400">
      <h2 class="text-3xl font-bold text-primary-700 mb-6 text-center">
        💰 Calculez votre mensualité
      </h2>

      <form id="pret-form" class="space-y-6">
        <div>
          <label for="montant" class="block text-sm font-semibold text-gray-700 mb-2">
            Montant à emprunter (€)
          </label>
          <input type="number" id="montant" name="montant" required
                 placeholder="Ex: 30000"
                 class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 <%= focus_ring %>">
        </div>

        <div>
          <label for="duree" class="block text-sm font-semibold text-gray-700 mb-2">
            Durée (années)
          </label>
          <select id="duree" name="duree" required
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 <%= focus_ring %>">
            <option value="5">5 ans</option>
            <option value="10">10 ans</option>
            <option value="15" selected>15 ans</option>
            <option value="20">20 ans</option>
            <option value="25">25 ans</option>
            <option value="30">30 ans</option>
          </select>
        </div>

        <div>
          <label for="taux" class="block text-sm font-semibold text-gray-700 mb-2">
            Taux d'intérêt (%)
          </label>
          <input type="number" id="taux" name="taux" step="0.1" required
                 placeholder="Ex: 1.5"
                 class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 <%= focus_ring %>">
          <p class="text-sm text-gray-500 mt-1">Entrez 0 pour un prêt à taux zéro</p>
        </div>

        <button type="submit"
                class="w-full bg-gradient-to-r from-primary-600 to-secondary-600 text-white px-8 py-4 rounded-lg font-bold text-lg hover:from-primary-700 hover:to-secondary-700 transition-all shadow-lg">
          📊 Calculer la mensualité
        </button>
      </form>

      <div id="pret-results" class="hidden mt-8 p-6 bg-gradient-to-r from-accent-50 to-amber-50 rounded-xl border border-accent-200">
        <h3 class="text-2xl font-bold text-primary-700 mb-4">Résultats</h3>
        <div id="pret-results-content"></div>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="py-12 bg-gradient-to-r from-primary-600 to-secondary-600 text-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl font-bold mb-4">
      Optimisez votre plan de financement
    </h2>
    <p class="text-xl mb-8 text-white/90">
      Combinez primes et prêts pour maximiser vos aides
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <%= link_to simulation_primes_path(@region),
          class: "bg-amber-400 text-primary-900 px-8 py-4 rounded-lg font-bold text-lg hover:bg-amber-500 transition-colors shadow-lg" do %>
        💰 Voir les primes
      <% end %>

      <%= link_to renovate_path,
          class: "bg-white text-primary-700 px-8 py-4 rounded-lg font-bold text-lg hover:bg-pearl-50 transition-colors" do %>
        🎯 Accompagnement Ren0vate
      <% end %>
    </div>
  </div>
</section>

<!-- Script -->
<script nonce="<%= content_security_policy_nonce %>">
document.addEventListener('DOMContentLoaded', function() {
  const form = document.getElementById('pret-form');
  const results = document.getElementById('pret-results');
  const resultsContent = document.getElementById('pret-results-content');

  form.addEventListener('submit', function(e) {
    e.preventDefault();

    const montant = parseFloat(document.getElementById('montant').value);
    const duree = parseInt(document.getElementById('duree').value);
    const taux = parseFloat(document.getElementById('taux').value);

    let mensualite;
    let coutTotal;
    let interets;

    if (taux === 0) {
      mensualite = montant / (duree * 12);
      coutTotal = montant;
      interets = 0;
    } else {
      const tauxMensuel = taux / 100 / 12;
      const nombreMensualites = duree * 12;
      mensualite = (montant * tauxMensuel) / (1 - Math.pow(1 + tauxMensuel, -nombreMensualites));
      coutTotal = mensualite * nombreMensualites;
      interets = coutTotal - montant;
    }

    resultsContent.innerHTML = `
      <div class="grid md:grid-cols-3 gap-6">
        <div class="text-center">
          <div class="text-4xl font-bold text-amber-400">
            ${Math.round(mensualite).toLocaleString('fr-BE')}€
          </div>
          <div class="text-sm text-gray-600 mt-1">Mensualité</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-bold text-secondary-500">
            ${Math.round(coutTotal).toLocaleString('fr-BE')}€
          </div>
          <div class="text-sm text-gray-600 mt-1">Coût total</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-bold text-gray-600">
            ${Math.round(interets).toLocaleString('fr-BE')}€
          </div>
          <div class="text-sm text-gray-600 mt-1">Intérêts</div>
        </div>
      </div>

      <div class="mt-6 p-4 bg-white rounded-lg border-l-4 border-accent-400">
        <p class="text-sm text-gray-700">
          <strong>Détails :</strong> Pour un prêt de ${montant.toLocaleString('fr-BE')}€
          sur ${duree} ans à ${taux}%, vous paierez ${Math.round(mensualite).toLocaleString('fr-BE')}€/mois.
        </p>
      </div>
    `;

    results.classList.remove('hidden');
    results.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });
});
</script>
