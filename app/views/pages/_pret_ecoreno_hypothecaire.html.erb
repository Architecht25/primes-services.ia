<div class="bg-gradient-to-br from-primary-50 to-primary-100 rounded-xl shadow-lg p-6 lg:p-8 border border-primary-200 hover:shadow-xl transition-shadow">
  <div class="flex items-start space-x-4">
    <div class="flex-shrink-0 w-16 h-16 bg-primary-600 rounded-full flex items-center justify-center text-3xl">
      🏦
    </div>
    <div class="flex-1">
      <h3 class="text-2xl font-bold text-gray-900 mb-3">
        Crédit Hypothécaire EcoRéno
      </h3>
      <p class="text-gray-700 mb-4">
        Financez l'achat et la rénovation énergétique de votre logement à Bruxelles avec un crédit hypothécaire à taux réduit du Fonds du Logement.
      </p>

      <div class="grid md:grid-cols-2 gap-4 mb-4">
        <div class="bg-white rounded-lg p-4">
          <div class="text-sm font-semibold text-primary-900 mb-1">💰 Montant</div>
          <div class="text-lg font-bold text-primary-700">Jusqu'à 120%</div>
          <div class="text-sm text-gray-600">de la valeur du bien</div>
        </div>
        <div class="bg-white rounded-lg p-4">
          <div class="text-sm font-semibold text-primary-900 mb-1">⏱️ Durée</div>
          <div class="text-sm text-gray-700">Maximum 30 ans</div>
        </div>
      </div>

      <div class="bg-white rounded-lg p-4 mb-4">
        <h4 class="font-semibold text-gray-900 mb-3">📊 Taux d'intérêt (2026) :</h4>
        <div class="space-y-2 text-sm text-gray-700">
          <div class="flex items-start justify-between p-2 bg-accent-50 rounded">
            <div>
              <strong>2,5%</strong> - Revenus bas
            </div>
            <div class="text-xs text-gray-600">
              Isolé < 45 600€ | Ménage < 60 600€
            </div>
          </div>
          <div class="flex items-start justify-between p-2 bg-secondary-50 rounded">
            <div>
              <strong>3,5%</strong> - Revenus moyens
            </div>
            <div class="text-xs text-gray-600">
              Isolé 45 600€-73 884€ | Ménage 60 600€-94 034€
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-lg p-4 mb-4">
        <h4 class="font-semibold text-gray-900 mb-2">✓ Avantages :</h4>
        <ul class="space-y-1 text-sm text-gray-700">
          <li>• Taux d'intérêt fixe et avantageux selon revenus</li>
          <li>• Financement jusqu'à 120% de la valeur du bien</li>
          <li>• Possibilité de reprise d'encours (min. 3 600€)</li>
          <li>• Mensualité minimum de 25€</li>
          <li>• Cumulable avec les primes Renolution</li>
          <li>• Accompagnement par Homegrade ou Réseau Habitat</li>
        </ul>
      </div>

      <div class="bg-white rounded-lg p-4 mb-4">
        <h4 class="font-semibold text-gray-900 mb-2">👥 Pour qui ?</h4>
        <ul class="space-y-1 text-sm text-gray-700">
          <li>• <strong>Futurs acquéreurs</strong> d'un logement à Bruxelles</li>
          <li>• <strong>Propriétaires-occupants</strong> souhaitant rénover</li>
          <li>• Revenus imposables < 73 884€ (isolé) ou 94 034€ (ménage)</li>
          <li>• Remboursement avant 70 ans du plus jeune emprunteur</li>
        </ul>
      </div>

      <div class="bg-white rounded-lg p-4 mb-4">
        <h4 class="font-semibold text-gray-900 mb-2">💼 Frais et garanties :</h4>
        <div class="grid md:grid-cols-2 gap-3 text-sm text-gray-700">
          <div>
            <strong>Frais :</strong>
            <ul class="mt-1 ml-4">
              <li>• Expertise : 324€</li>
              <li>• Dossier : 60€</li>
              <li>• Acte notarié</li>
            </ul>
          </div>
          <div>
            <strong>Garanties :</strong>
            <ul class="mt-1 ml-4">
              <li>• Hypothèque</li>
              <li>• Cession de créance</li>
              <li>• Assurance incendie</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="bg-amber-50 rounded-lg p-4 mb-4 border border-amber-200">
        <div class="flex items-start space-x-2">
          <span class="text-xl">⚠️</span>
          <div class="text-sm text-gray-700">
            <strong>Important :</strong> Le bien doit se situer dans l'une des 19 communes de Bruxelles-Capitale. Le montant dépend de votre capacité financière sans excéder 120% de la valeur du bien après travaux (expertise).
          </div>
        </div>
      </div>

      <div class="flex flex-wrap gap-3">
        <%= link_to "https://fonds.brussels/fr/emprunter/credit-ecoreno", target: "_blank", rel: "noopener",
            class: "inline-flex items-center px-5 py-3 bg-primary-600 text-white font-semibold rounded-lg hover:bg-primary-700 transition-colors shadow-md" do %>
          📖 Plus d'informations
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
          </svg>
        <% end %>
        <%= link_to "https://websimu.wffl.be/ecoreno/lang/fr", target: "_blank", rel: "noopener",
            class: "inline-flex items-center px-5 py-3 bg-white text-primary-600 font-semibold rounded-lg hover:bg-primary-50 transition-colors border border-primary-300" do %>
          🧮 Simulateur en ligne
        <% end %>
        <%= link_to "mailto:infopret@fonds.brussels?subject=Demande crédit EcoRéno hypothécaire",
            class: "inline-flex items-center px-5 py-3 bg-secondary-600 text-white font-semibold rounded-lg hover:bg-secondary-700 transition-colors shadow-md" do %>
          📝 Demander un RDV
        <% end %>
      </div>
    </div>
  </div>
</div>
