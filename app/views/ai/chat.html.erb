<% content_for :title, "Chat IA - Assistant Primes Services" %>

<div
  class="min-h-screen bg-pearl-50 flex flex-col"
  data-controller="ai-chat"
  data-ai-chat-conversation-id-value="<%= @conversation_stats[:session_id] %>"
  data-ai-chat-user-type-value="<%= session[:user_type] || 'visiteur' %>"
  data-ai-chat-user-region-value="<%= session[:user_region] || '' %>"
  data-ai-chat-api-url-value="/ai"
>
  <!-- Header du chat -->
  <header class="bg-gradient-to-r from-primary-600 to-primary-700 shadow-lg px-4 py-4">
    <div class="max-w-4xl mx-auto flex items-center justify-between">
      <div class="flex items-center space-x-3">
        <div class="w-12 h-12 bg-secondary-500 rounded-full flex items-center justify-center shadow-md">
          <span class="text-white text-xl">🤖</span>
        </div>
        <div>
          <h1 class="text-lg font-bold text-white">Assistant Primes Services</h1>
          <p class="text-sm text-white/90">Expert en primes de rénovation & prêts à taux 0% • Disponible 24/7</p>
        </div>
      </div>

      <div class="flex items-center space-x-2">
        <button
          data-action="click->ai-chat#resetChat"
          class="text-white/90 hover:text-white hover:bg-white/10 px-3 py-1 rounded text-sm transition-colors"
          title="Nouvelle conversation"
        >
          🔄 Reset
        </button>

        <button
          data-action="click->ai-chat#completeChat"
          class="bg-accent-400 text-white px-4 py-2 rounded-lg text-sm hover:bg-accent-500 transition-colors font-semibold shadow-md"
          title="Terminer la conversation"
        >
          ✓ Terminer
        </button>
      </div>
    </div>
  </header>

  <!-- Zone de chat -->
  <main class="flex-1 flex flex-col max-w-4xl mx-auto w-full">

    <!-- Messages container -->
    <div
      data-ai-chat-target="messages"
      class="flex-1 overflow-y-auto px-4 py-6 space-y-4"
      style="max-height: calc(100vh - 200px);"
    >

      <!-- Message de bienvenue -->
      <div class="flex justify-start mb-4">
        <div class="bg-white border-l-4 border-secondary-500 text-gray-800 rounded-lg px-4 py-3 max-w-md shadow-md">
          <div class="flex items-start space-x-2">
            <div class="w-8 h-8 bg-secondary-500 rounded-full flex items-center justify-center flex-shrink-0 mt-1 shadow-sm">
              <span class="text-white text-sm">🤖</span>
            </div>
            <div class="flex-1">
              <p class="text-sm">
                Bonjour ! Je suis votre assistant spécialisé en <strong class="text-primary-700">primes de rénovation énergétique et prêts à taux 0%</strong> en Belgique.
                <br><br>
                Je peux vous aider à :
                <br>
                💰 <strong class="text-amber-500">Calculer vos primes</strong> (régionales, communales, spécifiques)
                <br>
                🏦 <strong class="text-amber-500">Découvrir les prêts à 0%</strong> (Rénopack, Energielening, prêts verts)
                <br>
                🏛️ <strong class="text-accent-500">Primes patrimoine</strong> (monuments classés, petit patrimoine)
                <br>
                📊 <strong class="text-secondary-600">Audits & PEB</strong> (certifications énergétiques)
                <br>
                🏘️ <strong class="text-primary-600">Primes communales</strong> (cumulables avec les régionales)
                <br><br>
                Posez-moi vos questions sur votre projet de rénovation !
              </p>
              <span class="text-xs text-gray-500 block mt-2">
                <%= Time.current.strftime('%H:%M') %>
              </span>
            </div>
          </div>
        </div>
      </div>

      <!-- Historique existant -->
      <% if @conversation_history.present? %>
        <% @conversation_history.each do |message| %>
          <% if message['role'] == 'user' %>
            <div class="flex justify-end mb-4">
              <div class="bg-gradient-to-br from-primary-600 to-primary-700 text-white rounded-lg px-4 py-2 max-w-xs lg:max-w-md shadow-md">
                <p class="text-sm"><%= message['content'] %></p>
                <span class="text-xs text-white/80 block mt-1">
                  <%= Time.parse(message['timestamp']).strftime('%H:%M') rescue 'N/A' %>
                </span>
              </div>
            </div>
          <% elsif message['role'] == 'assistant' %>
            <div class="flex justify-start mb-4">
              <div class="bg-white border-l-4 border-secondary-500 text-gray-800 rounded-lg px-4 py-2 max-w-xs lg:max-w-md shadow-md">
                <div class="flex items-start space-x-2">
                  <div class="w-6 h-6 bg-secondary-500 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                    <span class="text-white text-xs">🤖</span>
                  </div>
                  <div class="flex-1">
                    <p class="text-sm whitespace-pre-wrap"><%= message['content'] %></p>
                    <span class="text-xs text-gray-500 block mt-1">
                      <%= Time.parse(message['timestamp']).strftime('%H:%M') rescue 'N/A' %>
                    </span>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        <% end %>
      <% end %>
    </div>

    <!-- Indicateur de frappe -->
    <div data-ai-chat-target="typingIndicator" class="px-4 hidden"></div>

    <!-- Suggestions rapides -->
    <div data-ai-chat-target="suggestions" class="px-4 py-2">
      <div class="suggestions-container">
        <p class="text-sm text-gray-600 mb-2 font-semibold">Questions populaires :</p>
        <div class="flex flex-wrap gap-2">
          <button
            data-action="click->ai-chat#sendSuggestion"
            data-message="Combien puis-je avoir pour isoler ma toiture ?"
            class="bg-amber-50 hover:bg-amber-100 text-amber-700 border border-amber-200 text-sm px-3 py-2 rounded-lg transition-colors font-medium"
          >
            💰 Primes isolation
          </button>

          <button
            data-action="click->ai-chat#sendSuggestion"
            data-message="Quels prêts à taux 0% sont disponibles pour mes travaux ?"
            class="bg-primary-50 hover:bg-primary-100 text-primary-700 border border-primary-200 text-sm px-3 py-2 rounded-lg transition-colors font-medium"
          >
            🏦 Prêts à 0%
          </button>

          <button
            data-action="click->ai-chat#sendSuggestion"
            data-message="Ma maison est classée, quelles primes pour le patrimoine ?"
            class="bg-accent-50 hover:bg-accent-100 text-accent-700 border border-accent-200 text-sm px-3 py-2 rounded-lg transition-colors font-medium"
          >
            🏛️ Patrimoine
          </button>

          <button
            data-action="click->ai-chat#sendSuggestion"
            data-message="Quelles primes communales puis-je cumuler avec les régionales ?"
            class="bg-secondary-50 hover:bg-secondary-100 text-secondary-700 border border-secondary-200 text-sm px-3 py-2 rounded-lg transition-colors font-medium"
          >
            🏘️ Primes communales
          </button>

          <button
            data-action="click->ai-chat#sendSuggestion"
            data-message="J'ai besoin d'un audit PEB, comment obtenir la prime ?"
            class="bg-primary-50 hover:bg-primary-100 text-primary-700 border border-primary-200 text-sm px-3 py-2 rounded-lg transition-colors font-medium"
          >
            📊 Audit/PEB
          </button>
        </div>
      </div>
    </div>

    <!-- Zone d'actions -->
    <div data-ai-chat-target="actions" class="px-4 py-2"></div>

    <!-- Zone de saisie -->
    <div class="bg-white border-t-2 border-primary-200 px-4 py-4 shadow-lg">
      <div class="flex items-end space-x-2">
        <div class="flex-1">
          <textarea
            data-ai-chat-target="input"
            placeholder="Posez votre question sur les primes, prêts à 0%, patrimoine..."
            class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 resize-none"
            rows="1"
            style="min-height: 40px; max-height: 120px;"
          ></textarea>
        </div>

        <button
          data-ai-chat-target="sendButton"
          data-action="click->ai-chat#sendMessage"
          class="bg-gradient-to-r from-primary-600 to-primary-700 hover:from-primary-700 hover:to-primary-800 disabled:bg-gray-300 disabled:cursor-not-allowed text-white px-6 py-3 rounded-lg transition-all font-semibold shadow-md"
          disabled
        >
          <span class="hidden sm:inline">Envoyer</span>
          <span class="sm:hidden">📤</span>
        </button>
      </div>

      <div class="mt-2 text-xs text-gray-500 text-center">
        Appuyez sur <kbd class="bg-pearl-100 px-2 py-1 rounded border border-gray-300 font-mono">Entrée</kbd> pour envoyer,
        <kbd class="bg-pearl-100 px-2 py-1 rounded border border-gray-300 font-mono">Shift + Entrée</kbd> pour une nouvelle ligne
      </div>
    </div>
  </main>
</div>

<!-- Styles CSS personnalisés -->
<style>
  /* Animation pour les points de frappe */
  .typing-dots {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .typing-dots span {
    width: 6px;
    height: 6px;
    background-color: #6b7280;
    border-radius: 50%;
    animation: typing 1.4s infinite;
  }

  .typing-dots span:nth-child(2) {
    animation-delay: 0.2s;
  }

  .typing-dots span:nth-child(3) {
    animation-delay: 0.4s;
  }

  @keyframes typing {
    0%, 60%, 100% {
      transform: translateY(0);
      opacity: 0.5;
    }
    30% {
      transform: translateY(-10px);
      opacity: 1;
    }
  }

  /* Scroll personnalisé */
  .messages::-webkit-scrollbar {
    width: 6px;
  }

  .messages::-webkit-scrollbar-track {
    background: #f1f5f9;
  }

  .messages::-webkit-scrollbar-thumb {
    background: #cbd5e1;
    border-radius: 3px;
  }

  .messages::-webkit-scrollbar-thumb:hover {
    background: #94a3b8;
  }

  /* Animation des messages */
  .message {
    animation: messageSlideIn 0.3s ease-out;
  }

  @keyframes messageSlideIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Responsive adjustments */
  @media (max-width: 640px) {
    .max-w-xs {
      max-width: 85%;
    }

    .max-w-md {
      max-width: 85%;
    }
  }
</style>
